{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ganesh/sdd-knowledgebase-evaluation/docs/judge-output-schema.json",
  "title": "KB-Approach Judge Verdict",
  "description": "Structured, evidence-backed result of comparing three knowledge-base approaches' specs for one feature story. Adapted from the llm-pr-judge verdict schema for a 3-way comparison.",
  "type": "object",
  "required": ["story", "options", "overall", "groups"],
  "additionalProperties": false,
  "properties": {
    "story": { "type": "string", "description": "Identifier or path of the feature story (the ground truth)." },
    "mode": {
      "type": "string",
      "enum": ["pairwise", "reference"],
      "default": "pairwise",
      "description": "pairwise = the three specs vs. each other + the story; reference = each spec vs. tasks/<ID>/gold-impact.json."
    },
    "options": {
      "type": "object",
      "required": ["a", "b", "c"],
      "additionalProperties": false,
      "properties": {
        "a": { "type": "string", "description": "Approach A — markdown" },
        "b": { "type": "string", "description": "Approach B — graph-rag" },
        "c": { "type": "string", "description": "Approach C — graph-mcp" }
      }
    },
    "overall": {
      "type": "object",
      "required": ["winner", "ranking", "margin", "summary"],
      "additionalProperties": false,
      "properties": {
        "winner": { "type": "string", "enum": ["a", "b", "c", "tie"] },
        "ranking": {
          "type": "array",
          "items": { "type": "string", "enum": ["a", "b", "c"] },
          "description": "Approach ids best-to-worst by weighted score."
        },
        "scores": { "$ref": "#/$defs/triple" },
        "margin": {
          "type": "number", "minimum": 0, "maximum": 1,
          "description": "top_score - second_score. Below 0.10 set recommend_human_review."
        },
        "recommend_human_review": { "type": "boolean", "default": false },
        "summary": { "type": "string", "description": "1-3 sentence rationale." }
      }
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "weight", "scores", "criteria"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "enum": ["impact_completeness", "scope_precision", "contract_precision", "determinism", "spec_usability"]
          },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "winner": { "type": "string", "enum": ["a", "b", "c", "tie"] },
          "scores": { "$ref": "#/$defs/triple" },
          "criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "scores", "confidence", "evidence"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "description": "Rubric criterion id, e.g. G1, G4." },
                "scores": { "$ref": "#/$defs/triple" },
                "confidence": { "type": "string", "enum": ["high", "med", "low"] },
                "evidence": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" },
                  "description": "Concrete citations: 'graph-mcp names inventory-service (AC3 changes order.created); markdown omits it'. No claim without one."
                }
              }
            }
          }
        }
      }
    },
    "order_sensitive_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Criterion ids whose ranking changed when the spec order was rotated.",
      "default": []
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Per-approach weaknesses worth surfacing regardless of who won.",
      "default": []
    }
  },
  "$defs": {
    "triple": {
      "type": "object",
      "required": ["a", "b", "c"],
      "additionalProperties": false,
      "properties": {
        "a": { "type": "number", "minimum": 0, "maximum": 1 },
        "b": { "type": "number", "minimum": 0, "maximum": 1 },
        "c": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
